{
  "name": "label-studio-zebra",
  "version": "1.0.2",
  "main": "main.js",
  "author": "Brandon Ventura <brandonstanlyv@gmail.com>",
  "description": "Ing. Brandon Ventura (El Guapo)",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.bventura.vin-label-studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": null
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stanlydev/vin-label-studio.git"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}